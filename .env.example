# Copy this file to .env and replace the placeholder values.
# Do not commit real secrets to version control.

# Stripe server configuration
# Use an sk_test key while developing locally. Replace it with your sk_live key before going live.
STRIPE_SECRET_KEY=sk_test_your_test_key_here
# Set this to true in production so the server refuses Checkout requests unless STRIPE_SECRET_KEY is live.
STRIPE_LIVE_MODE_REQUIRED=false

# This must match the public URL of the website that sends donors back after checkout.
FRONTEND_URL=http://localhost:8080
PORT=4242

# Frontend -> server API base URL
# In production this should point to the public URL of the helper server.
VITE_API_BASE_URL=http://localhost:4242

# YouTube channel configuration
YOUTUBE_CHANNEL_ID=UCPGf8ENeO4j7Wglu-i4PDWg
YOUTUBE_CHANNEL_URL=https://www.youtube.com/@universalchristianfaithmin8602
YOUTUBE_LATEST_SERVICE_VIDEO_ID=_m546XuYrag

# Optional: add a YouTube Data API key to sync the live broadcast and latest completed service.
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# Optional: override cache duration in milliseconds for YouTube API responses.
YOUTUBE_CACHE_TTL_MS=1800000
